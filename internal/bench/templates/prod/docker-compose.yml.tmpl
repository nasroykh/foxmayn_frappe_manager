x-logging: &default-logging
  driver: json-file
  options:
    max-size: "10m"
    max-file: "3"

services:
{{- if eq .DBType "postgres"}}
  postgres:
    image: docker.io/postgres:18
    environment:
      POSTGRES_PASSWORD: "{{.DBRootPassword}}"
    volumes:
      - postgres-data:/var/lib/postgresql
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 10s
      timeout: 5s
      retries: 10
    restart: unless-stopped
    logging: *default-logging
{{- else}}
  mariadb:
    image: docker.io/mariadb:11.8
    command:
      - --character-set-server=utf8mb4
      - --collation-server=utf8mb4_unicode_ci
      - --skip-character-set-client-handshake
      - --skip-innodb-read-only-compressed
      - --innodb-buffer-pool-size={{.MariaDBBufferPool}}
      - --innodb-log-file-size=256M
      - --innodb-flush-log-at-trx-commit=2
      - --innodb-flush-method=O_DIRECT
      - --tmp-table-size=64M
      - --max-heap-table-size=64M
      - --join-buffer-size=2M
      - --sort-buffer-size=2M
{{- if .SlowQueryLog}}
      - --slow-query-log=1
      - --slow-query-log-file=/var/log/mysql/slow.log
      - --long-query-time=2
{{- end}}
    environment:
      MYSQL_ROOT_PASSWORD: "{{.DBRootPassword}}"
      MARIADB_AUTO_UPGRADE: 1
    volumes:
      - mariadb-data:/var/lib/mysql
{{- if .SlowQueryLog}}
      - ./mysql-logs:/var/log/mysql
{{- end}}
    healthcheck:
      test: ["CMD", "mariadb", "-u", "root", "-p{{.DBRootPassword}}", "-e", "SELECT 1"]
      interval: 10s
      timeout: 5s
      retries: 10
    restart: unless-stopped
    logging: *default-logging
{{- end}}

  redis-cache:
    image: docker.io/redis:alpine
    command: ["redis-server", "--maxmemory", "{{.RedisCacheMaxmem}}", "--maxmemory-policy", "allkeys-lru"]
    restart: unless-stopped
    logging: *default-logging

  redis-queue:
    image: docker.io/redis:alpine
    command: ["redis-server", "--maxmemory", "{{.RedisQueueMaxmem}}", "--maxmemory-policy", "noeviction"]
    restart: unless-stopped
    logging: *default-logging

  frappe:
    build:
      context: .
    command: ["bash", "-c", "cd /workspace/frappe-bench && env/bin/gunicorn --chdir /workspace/frappe-bench/sites -b 0.0.0.0:8000 -w {{.GunicornWorkers}} --threads 4 -t 120 wsgi:application"]
    working_dir: /workspace/frappe-bench
    volumes:
      - ./workspace:/workspace
      - ./wsgi.py:/workspace/frappe-bench/sites/wsgi.py:ro
      - pip-cache:/home/frappe/.cache/pip
      - yarn-cache:/home/frappe/.cache/yarn
    ports:
      - "{{.WebPort}}:8000"
    depends_on:
{{- if eq .DBType "postgres"}}
      postgres:
        condition: service_healthy
{{- else}}
      mariadb:
        condition: service_healthy
{{- end}}
    restart: unless-stopped
    logging: *default-logging
    networks:
      default: {}
      ffm-proxy: {}
    labels:
{{- if .NoSSL}}
      - "traefik.enable=true"
      - "traefik.docker.network=ffm-proxy"
      - "traefik.http.routers.{{.Name}}.rule=Host(`{{.Domain}}`)"
      - "traefik.http.routers.{{.Name}}.entrypoints=web"
      - "traefik.http.services.{{.Name}}.loadbalancer.server.port=8000"
{{- else}}
      - "traefik.enable=true"
      - "traefik.docker.network=ffm-proxy"
      # HTTPS router
      - "traefik.http.routers.{{.Name}}.rule=Host(`{{.Domain}}`)"
      - "traefik.http.routers.{{.Name}}.entrypoints=websecure"
      - "traefik.http.routers.{{.Name}}.tls.certresolver=letsencrypt"
      - "traefik.http.services.{{.Name}}.loadbalancer.server.port=8000"
      # HTTP → HTTPS redirect (per-bench, leaves dev benches on :80 untouched)
      - "traefik.http.routers.{{.Name}}-redirect.rule=Host(`{{.Domain}}`)"
      - "traefik.http.routers.{{.Name}}-redirect.entrypoints=web"
      - "traefik.http.middlewares.{{.Name}}-redirect.redirectscheme.scheme=https"
      - "traefik.http.routers.{{.Name}}-redirect.middlewares={{.Name}}-redirect"
{{- end}}

  socketio:
    build:
      context: .
    command: ["bash", "-c", "cd /workspace/frappe-bench && node apps/frappe/socketio.js"]
    environment:
      - FRAPPE_SOCKETIO_PORT=9000
    working_dir: /workspace/frappe-bench
    volumes:
      - ./workspace:/workspace
    ports:
      - "{{.SocketIOPort}}:9000"
    depends_on:
      - frappe
    restart: unless-stopped
    logging: *default-logging
    networks:
      default: {}
      ffm-proxy: {}
    labels:
{{- if .NoSSL}}
      - "traefik.enable=true"
      - "traefik.docker.network=ffm-proxy"
      - "traefik.http.routers.{{.Name}}-socketio.rule=Host(`{{.Domain}}`) && PathPrefix(`/socket.io`)"
      - "traefik.http.routers.{{.Name}}-socketio.entrypoints=web"
      - "traefik.http.services.{{.Name}}-socketio.loadbalancer.server.port=9000"
{{- else}}
      - "traefik.enable=true"
      - "traefik.docker.network=ffm-proxy"
      - "traefik.http.routers.{{.Name}}-socketio.rule=Host(`{{.Domain}}`) && PathPrefix(`/socket.io`)"
      - "traefik.http.routers.{{.Name}}-socketio.entrypoints=websecure"
      - "traefik.http.routers.{{.Name}}-socketio.tls.certresolver=letsencrypt"
      - "traefik.http.services.{{.Name}}-socketio.loadbalancer.server.port=9000"
{{- end}}

  worker-long:
    build:
      context: .
    command: ["bash", "-c", "cd /workspace/frappe-bench && bench worker --queue long"]
    working_dir: /workspace/frappe-bench
    volumes:
      - ./workspace:/workspace
      - pip-cache:/home/frappe/.cache/pip
    depends_on:
      - frappe
    restart: unless-stopped
    logging: *default-logging
    deploy:
      replicas: {{.WorkerLongCount}}

  worker-short:
    build:
      context: .
    command: ["bash", "-c", "cd /workspace/frappe-bench && bench worker --queue short"]
    working_dir: /workspace/frappe-bench
    volumes:
      - ./workspace:/workspace
      - pip-cache:/home/frappe/.cache/pip
    depends_on:
      - frappe
    restart: unless-stopped
    logging: *default-logging
    deploy:
      replicas: {{.WorkerShortCount}}

  scheduler:
    build:
      context: .
    command: ["bash", "-c", "cd /workspace/frappe-bench && bench schedule"]
    working_dir: /workspace/frappe-bench
    volumes:
      - ./workspace:/workspace
      - pip-cache:/home/frappe/.cache/pip
    depends_on:
      - frappe
    restart: unless-stopped
    logging: *default-logging

volumes:
{{- if eq .DBType "postgres"}}
  postgres-data:
{{- else}}
  mariadb-data:
{{- end}}
  pip-cache:
  yarn-cache:

networks:
  default: {}
  ffm-proxy:
    external: true
