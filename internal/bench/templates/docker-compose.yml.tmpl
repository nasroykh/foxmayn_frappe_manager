services:
  mariadb:
    image: docker.io/mariadb:11.8
    command:
      - --character-set-server=utf8mb4
      - --collation-server=utf8mb4_unicode_ci
      - --skip-character-set-client-handshake
      - --skip-innodb-read-only-compressed
    environment:
      MYSQL_ROOT_PASSWORD: "{{.MariaDBRootPassword}}"
      MARIADB_AUTO_UPGRADE: 1
    volumes:
      - mariadb-data:/var/lib/mysql

  redis-cache:
    image: docker.io/redis:alpine

  redis-queue:
    image: docker.io/redis:alpine

  frappe:
    build:
      context: .
      args:
        FRAPPE_BRANCH: "{{.FrappeBranch}}"
    command: sleep infinity
    environment:
      - SHELL=/bin/zsh
{{- if .ForwardSSHAgent}}
      - SSH_AUTH_SOCK=/ssh-agent
{{- end}}
    volumes:
      - frappe-bench:/home/frappe/frappe-bench
      - {{.BenchDir}}:/workspace:cached
{{- if .ForwardSSHAgent}}
      - ${SSH_AUTH_SOCK}:/ssh-agent
{{- end}}
    working_dir: /workspace
    ports:
      - "{{.WebPort}}-{{.WebPortEnd}}:8000-8005"
      - "{{.SocketIOPort}}-{{.SocketIOPortEnd}}:9000-9005"
    networks:
      default: {}
      ffm-proxy: {}
    labels:
      # Traefik reverse-proxy labels — enable sitename.localhost routing.
      # These are harmless when the proxy is not running.
      - "traefik.enable=true"
      # Scope routing to the shared ffm-proxy network to prevent Traefik from
      # randomly selecting the wrong network when a container has multiple NICs.
      - "traefik.docker.network=ffm-proxy"
      - "traefik.http.routers.{{.Name}}.rule=Host(`{{.Name}}.localhost`)"
      - "traefik.http.routers.{{.Name}}.entrypoints=web"
      - "traefik.http.services.{{.Name}}.loadbalancer.server.port=8000"

volumes:
  mariadb-data:
  frappe-bench:

networks:
  # The default network is implicit but must be listed explicitly once the
  # frappe service declares its own networks block.
  default: {}
  # Shared external network managed by 'ffm proxy start'.
  # The network is created automatically by 'ffm create' (even without the
  # proxy running) so that docker compose up never fails due to a missing
  # external network.
  ffm-proxy:
    external: true
